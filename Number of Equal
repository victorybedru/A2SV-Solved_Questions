n,m = map(int,input().split())
a= list(map(int,input().split()))
b= list(map(int,input().split()))
i=0
j=0
count=0
while i<n and j<m:
    if a[i]<b[j]:
        i+=1
    elif a[i]>b[j]:
        j+=1
    else:
        val= a[i]
        counta=0
        countb=0
        while i<n and counta==val:
            counta+=1
            i+=1
        while j<m and countb==val:
            countb+=1 
            j+=1
        count+=(counta*countb) 
print(count)
