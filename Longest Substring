class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        nonRepeat= set()
        left=0
        longest=0
        for right in range(len(s)):
            while s[right] in nonRepeat:
                nonRepeat.remove(s[left])
                left+=1
            nonRepeat.add(s[right])
            longest= max(longest, right-left+1)
        return longest


